{
  "openapi": "3.0.0",
  "info": {
    "title": "My API",
    "version": "1.0.0"
  },
  "paths": {
    "/": {
      "get": {
        "summary": "Welcome dashboard",
        "description": "Check if API is working",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "Welcome to Api"
                }
              }
            }
          }
        }
      }
    },

    "/api/book": {
      "post": {
        "summary": "Create a new book",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBook"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Book created successfully",
            "content": {
              "application/json": {
                "example": {
                  "message": "Book created successfully",
                  "data": {
                    "id": 1,
                    "bookName": "Atomic Habits",
                    "price": 100,
                    "author": [{ "name": "James Clear" }],
                    "publisher": "Hamdard"
                  }
                }
              }
            }
          }
        }
      },

      "get": {
        "summary": "Get all books (with filters)",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "example": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "example": 5 }
          },
          {
            "name": "author",
            "in": "query",
            "schema": { "type": "string", "example": "Zain Ali" }
          },
          {
            "name": "minPrice",
            "in": "query",
            "schema": { "type": "number", "example": 50 }
          },
          {
            "name": "maxPrice",
            "in": "query",
            "schema": { "type": "number", "example": 200 }
          }
        ],
        "responses": {
          "200": {
            "description": "Books fetched successfully",
            "content": {
              "application/json": {
                "examples": {
                  "pagination": {
                    "value": {
                      "total": 20,
                      "page": 1,
                      "limit": 5,
                      "data": [
                        {
                          "id": 1,
                          "bookName": "Atomic Habits",
                          "price": 100,
                          "author": [{ "name": "James Clear" }],
                          "publisher": "Hamdard"
                        }
                      ]
                    }
                  },
                  "filtered": {
                    "value": {
                      "total": 2,
                      "page": 1,
                      "limit": 5,
                      "data": [
                        {
                          "id": 3,
                          "bookName": "Deep Work",
                          "price": 150,
                          "author": [{ "name": "Zain Ali" }],
                          "publisher": "XYZ"
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },

    "/api/book/{id}": {
      "get": {
        "summary": "Get book by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Book fetched successfully",
            "content": {
              "application/json": {
                "example": {
                  "message": "Book fetched successfully",
                  "data": {
                    "id": 1,
                    "bookName": "Atomic Habits",
                    "price": 100,
                    "author": [{ "name": "James Clear" }],
                    "publisher": "Hamdard"
                  }
                }
              }
            }
          }
        }
      },

      "put": {
        "summary": "Update book",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBook"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Book updated successfully"
          }
        }
      },

      "delete": {
        "summary": "Delete book",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Book deleted successfully"
          }
        }
      }
    }
  },

  "components": {
    "schemas": {
      "CreateBook": {
        "type": "object",
        "required": ["bookName", "author", "price"],
        "properties": {
          "bookName": {
            "type": "string",
            "example": "Atomic Habits"
          },
          "author": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["James Clear"]
          },
          "price": {
            "type": "number",
            "example": 100
          },
          "publisher": {
            "type": "string",
            "example": "Hamdard"
          }
        }
      }
    }
  }
}
