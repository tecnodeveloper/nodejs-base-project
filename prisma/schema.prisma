generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User { 
  id    Int     @id @default(autoincrement()) 
  name  String?
  email String  @unique
  password String
}

model Book {
  id Int @id @default(autoincrement())
  bookName String @default("-")
  author Author[] 
  price Float @default(0)
  publisher String? @default("-")
}

model Author{
  id Int @id @default(autoincrement())
  name String
  books Book[]
}
